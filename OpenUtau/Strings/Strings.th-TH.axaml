  <system:String x:Key="dialogs.installdll.message">กำลังติดตั้ง </system:String>
  <system:String x:Key="dialogs.messagebox.cancel">ยกเลิก</system:String>
  <system:String x:Key="dialogs.messagebox.copy">คัดลอกข้อผิดพลาด</system:String>
