# Made And Checked By DELTA SYNTH & Gemini AI
# เพื่อความเป็นระเบียบและสมบูรณ์แบบของซอร์สโค้ด OpenUtau

# ---------------------------------------------------------
# การตั้งค่าพื้นฐานสำหรับทุกไฟล์
# ---------------------------------------------------------
[*]
indent_style = space            # ใช้ Space แทน Tab เพื่อความคงที่ของระยะย่อหน้า
indent_size = 4                 # กำหนดขนาดการย่อหน้าเป็น 4 ช่อง
end_of_line = crlf              # มาตรฐานการขึ้นบรรทัดใหม่สำหรับ Windows
insert_final_newline = true     # เพิ่มบรรทัดว่างท้ายไฟล์เสมอ
trim_trailing_whitespace = true # ลบช่องว่างส่วนเกินที่ปลายบรรทัดโดยอัตโนมัติ

# ---------------------------------------------------------
# มาตรฐานการเขียนโค้ดสำหรับ C# และ VB
# ---------------------------------------------------------
[*.{cs,csx,vb,vbx}]
charset = utf-8-bom             # ใช้ Encoding แบบ UTF-8 พร้อม BOM สำหรับ Visual Studio
guidelines = 100                # กำหนดเส้นนำสายตาที่ 100 ตัวอักษร

# การจัดการ Using
dotnet_sort_system_directives_first = true # จัดเรียง System ไว้ด้านบนสุดเสมอ

# ---------------------------------------------------------
# กฎความสวยงามของโค้ด (Naming & Coding Conventions)
# ---------------------------------------------------------
[*.{cs,vb}]
# ไม่ต้องใช้ "this." หากไม่จำเป็น
dotnet_style_qualification_for_field = false:silent
dotnet_style_qualification_for_property = false:silent

# การใช้ตัวแปรแบบ Implicit (var)
csharp_style_var_for_built_in_types = true:silent
csharp_style_var_when_type_is_apparent = true:silent

# การจัดลำดับ Modifiers (public, private, static, etc.)
csharp_preferred_modifier_order = public,private,protected,internal,static,extern,new,virtual,abstract,sealed,override,readonly,unsafe,volatile,async:suggestion

# ---------------------------------------------------------
# กฎการจัดรูปแบบเว้นวรรคและวงเล็บ (Formatting)
# ---------------------------------------------------------
[*.cs]
# วงเล็บปีกกา { } ไม่ต้องขึ้นบรรทัดใหม่ในบางกรณีเพื่อความกระชับ
csharp_new_line_before_open_brace = none
csharp_new_line_before_else = false
csharp_new_line_before_catch = false

# การเว้นวรรคในคำสั่งควบคุม
csharp_space_after_keywords_in_control_flow_statements = true
csharp_space_around_binary_operators = before_and_after

# ---------------------------------------------------------
# สำหรับไฟล์โปรเจกต์อื่นๆ
# ---------------------------------------------------------
[*.{json,xml,axaml,xaml}]
indent_size = 2 # ไฟล์โครงสร้าง UI และ Data ใช้ย่อหน้า 2 ช่องเพื่อความสบายตา
